        font-weight: bold;
    }
        
    QPushButton#btnLogin:hover {
        background-color: #1976D2;
    }
        
    QPushButton#btnLogin:pressed {
        background-color: #0D47A1;
    }
        
    QPushButton#btnResetPwd {
        background-color: transparent;
